---
import { APP_NAME } from '../lib/brand-assets';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{APP_NAME} Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#242452">
    <link rel="icon" type="image/png" href="/business-card/Assets/DigiCard_Favicon_Light.png" media="(prefers-color-scheme: light)">
    <link rel="icon" type="image/png" href="/business-card/Assets/DigiCard_Favicon_Dark.png" media="(prefers-color-scheme: dark)">
    <link rel="icon" type="image/png" href="/business-card/Assets/DigiCard_Favicon_Light.png" data-brand-favicon>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/business-card/styles.css">
</head>
<body>
    <div class="app-container admin-page">
        <header class="header">
            <div class="logo">
                <img class="logo-image logo-light" src="/business-card/Assets/DigiCard-Logo_Light.png" alt="Sojern DigiCard" width="300" height="41">
                <img class="logo-image logo-dark" src="/business-card/Assets/DigiCard-Logo_Dark.png" alt="Sojern DigiCard" width="300" height="41">
            </div>
        </header>

        <main class="admin-main">
            <h1 class="admin-title">Card admin</h1>
            <p class="helper-text admin-intro">Review and remove spam or unused cards. Requires <code>DIGICARD_ADMIN_KEY</code> configured in Webflow Cloud.</p>

            <form id="adminAuthForm" class="admin-auth-form">
                <div class="form-field">
                    <label for="adminKey">Admin key</label>
                    <input type="password" id="adminKey" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn btn-primary" id="loadCardsBtn">Load cards</button>
            </form>

            <div class="admin-status hidden" id="adminStatus"></div>

            <div class="admin-table-wrap hidden" id="adminTableWrap">
                <div class="admin-toolbar">
                    <label class="admin-filter admin-filter--search" for="adminSearch">
                        <span class="admin-filter-label">Search</span>
                        <div class="admin-search-row">
                            <input
                                type="search"
                                id="adminSearch"
                                class="admin-filter-input"
                                placeholder="Name or email"
                                autocomplete="off"
                            >
                            <button type="button" class="btn btn-secondary btn-sm admin-search-clear hidden" id="adminSearchClear">Clear</button>
                        </div>
                    </label>
                    <label class="admin-filter" for="adminTemplateFilter">
                        <span class="admin-filter-label">Template</span>
                        <select id="adminTemplateFilter" class="admin-filter-select">
                            <option value="">All templates</option>
                            <option value="sojern">Sojern Branded</option>
                            <option value="rategain">RateGain Branded</option>
                        </select>
                    </label>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Template</th>
                            <th>Slug</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="adminTableBody"></tbody>
                </table>
                <button type="button" class="btn btn-secondary hidden" id="loadMoreCardsBtn">Load more</button>
            </div>
        </main>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <script is:inline src="/business-card/brand.js"></script>
    <script is:inline src="/business-card/admin.js"></script>
</body>
</html>
