---
import { getCardBySlug, buildCardUrls } from '../../lib/cards-store';
import { APP_NAME, APPLE_TOUCH_ICON, FAVICON_DARK, FAVICON_LIGHT } from '../../lib/brand-assets';
import { getPublicOrigin } from '../../lib/site-url';
import { isReservedSlug } from '../../lib/reserved-slugs';

export const prerender = false;

const { slug } = Astro.params;
if (!slug || isReservedSlug(slug)) {
    return Astro.redirect('/business-card/');
}

let card = null;
try {
    card = await getCardBySlug(Astro.locals, slug);
} catch {
    card = null;
}

if (!card) {
    return new Response('Card not found', { status: 404 });
}

const origin = getPublicOrigin(Astro.url.origin, Astro.locals);
const urls = buildCardUrls(origin, slug, card.editKey);
const templateId = card.templateId;
const contactUrl = urls.contactUrl;
const vcfUrl = urls.vcfUrl;
const fullName = card.cardData.fullName;
const manifestUrl = `/business-card/${slug}/manifest.webmanifest`;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{fullName} — DigiCard</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content={APP_NAME}>
    <meta name="theme-color" content="#242452">
    <link rel="manifest" href={manifestUrl}>
    <link rel="icon" type="image/png" href={FAVICON_LIGHT} media="(prefers-color-scheme: light)">
    <link rel="icon" type="image/png" href={FAVICON_DARK} media="(prefers-color-scheme: dark)">
    <link rel="apple-touch-icon" href={APPLE_TOUCH_ICON}>
    <link rel="apple-touch-icon" sizes="180x180" href={APPLE_TOUCH_ICON}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/business-card/styles.css">
</head>
<body class={`public-card-page share-card-page${templateId === 'rategain' ? ' public-card-page--rategain' : ''}`}>
    <main class="public-card-main">
        <div class="share-top-panel">
            <div class="share-qr-panel">
                <canvas id="shareQrCanvas" width="220" height="220" aria-label="QR code to share contact"></canvas>
                <p class="share-qr-label">Scan to save my contact</p>
            </div>

            <button type="button" class="btn btn-primary share-contact-btn" id="shareContactBtn">
                Share Contact
            </button>
            <p class="helper-text share-contact-hint">Send via AirDrop or Messages to a nearby iPhone</p>
        </div>

        <div id="cardPreviewMount" class="sojern-card-mount public-card-mount"></div>

        <p class="share-home-link-wrap">
            <button type="button" class="share-home-link" id="shareHomeScreenLink">Save to your phone's Home Screen</button>
        </p>
    </main>

    <div class="modal-overlay hidden" id="shareHomeScreenModal">
        <div class="modal-card modal-card--wide modal-card--scroll">
            <button type="button" class="modal-close" id="shareHomeScreenClose" aria-label="Close">&times;</button>
            <h2 class="modal-title">Add to Home Screen</h2>
            <div id="homeScreenGuideShareMount"></div>
        </div>
    </div>

    <script is:inline src="/business-card/vendor/qrcode.min.js"></script>
    <script is:inline src="/business-card/card-fields.js"></script>
    <script is:inline src="/business-card/card-icons.js"></script>
    <script is:inline src="/business-card/card-templates.js"></script>
    <script is:inline src="/business-card/contact-page.js"></script>
    <script is:inline src="/business-card/home-screen-guide.js"></script>
    <script is:inline define:vars={{ cardData: card.cardData, templateId, contactUrl, vcfUrl, fullName, shareUrl: urls.shareUrl }}>
        const mount = document.getElementById('cardPreviewMount');
        if (mount && window.CardTemplates) {
            window.CardTemplates.render(mount, templateId, cardData);
        }

        const canvas = document.getElementById('shareQrCanvas');
        if (canvas && typeof QRCode !== 'undefined') {
            QRCode.toCanvas(canvas, contactUrl, {
                width: 220,
                margin: 1,
                color: { dark: '#242452', light: '#ffffff' }
            });
        }

        const homeScreenModal = document.getElementById('shareHomeScreenModal');
        const openHomeScreenGuide = () => {
            HomeScreenGuide.mount(document.getElementById('homeScreenGuideShareMount'), {
                shareUrl,
                variant: 'full'
            });
            homeScreenModal?.classList.remove('hidden');
        };

        document.getElementById('shareHomeScreenLink')?.addEventListener('click', openHomeScreenGuide);
        document.getElementById('shareHomeScreenClose')?.addEventListener('click', () => {
            homeScreenModal?.classList.add('hidden');
        });
        homeScreenModal?.addEventListener('click', (e) => {
            if (e.target === homeScreenModal) homeScreenModal.classList.add('hidden');
        });

        document.getElementById('shareContactBtn')?.addEventListener('click', async () => {
            const btn = document.getElementById('shareContactBtn');
            btn.disabled = true;
            try {
                await shareContactFile(vcfUrl, fullName);
            } catch (err) {
                console.error(err);
            } finally {
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
